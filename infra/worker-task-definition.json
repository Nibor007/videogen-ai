{
  "family": "videogen-worker",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::574772738554:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "videogen-worker",
      "image": "574772738554.dkr.ecr.us-east-1.amazonaws.com/videogen-worker:latest",
      "environment": [
        {"name": "AWS_REGION", "value": "us-east-1"},
        {"name": "S3_BUCKET", "value": "videogen-assets-574772738554"},
        {"name": "SQS_QUEUE_URL", "value": "https://sqs.us-east-1.amazonaws.com/574772738554/videogen-main"},
        {"name": "SQS_DLQ_URL", "value": "https://sqs.us-east-1.amazonaws.com/574772738554/videogen-dlq"},
        {"name": "DATABASE_URL", "value": "postgresql://videogenadmin:VideoGen2024!@videogen-db.cupmsgwqevte.us-east-1.rds.amazonaws.com:5432/videogen"},
        {"name": "LANGCHAIN_TRACING_V2", "value": "true"},
        {"name": "LANGCHAIN_PROJECT", "value": "videogen-ai"},
        {"name": "LANGCHAIN_ENDPOINT", "value": "https://api.smith.langchain.com"}
      ],
      "secrets": [
        {"name": "ANTHROPIC_API_KEY", "valueFrom": "arn:aws:secretsmanager:us-east-1:574772738554:secret:videogen/api-keys:ANTHROPIC_API_KEY::"},
        {"name": "FISH_API_KEY", "valueFrom": "arn:aws:secretsmanager:us-east-1:574772738554:secret:videogen/api-keys:FISH_API_KEY::"},
        {"name": "FISH_VOICE_ID", "valueFrom": "arn:aws:secretsmanager:us-east-1:574772738554:secret:videogen/api-keys:FISH_VOICE_ID::"},
        {"name": "LANGCHAIN_API_KEY", "valueFrom": "arn:aws:secretsmanager:us-east-1:574772738554:secret:videogen/api-keys:LANGCHAIN_API_KEY::"}
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/videogen-worker",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "essential": true
    }
  ]
}